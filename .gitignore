# Root level gitignore

# Environment files
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude/ngrok temp files
ngrok.yml
.claude/

# Service account keys
*-service-account.json

# Dependencies
node_modules/

# Old files
*.tsx.bak

.vercel

# Serena MCP cache
.serena/

# Scratch / working files (not source).
# Root-level .docx only — backend/assets/*.docx templates are real build assets.
sql_skus*.json
frontend/nul
/*.docx
~$*.docx
