{
  "_meta": {
    "description": "Catalog for the in-session structured assessment panel (Phase 3 of the scribe context upgrades). Each measure's `key` MUST equal a test key in normative-data.json so the deterministic engine (normative-data.interpretByKey) grades the captured value against age/sex norms — exactly the same grounding the handout uses, but from a tapped number rather than text extracted from speech. The UI is fully driven by this file: adding an assessment is data, not code. Assessments are grouped by `category` in the picker.",
    "laterality": {
      "bilateral": "Capture a left and a right value (each stored as its own row). The norm is not side-specific; a >10% side-to-side gap is flagged at grading.",
      "single": "One value for the whole body (stored with side='bilateral'). Use for non-lateralised tests."
    },
    "input": {
      "presets": "Tablet-fast: tappable preset buttons from min→max in `presetStep` increments (e.g. ROM eyeballed to the nearest 10°). Tapping commits and advances.",
      "keypad": "On-screen numeric keypad for an exact instrument read (dynamometer kg, stopwatch seconds, counts, mmol/L)."
    }
  },
