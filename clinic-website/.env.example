# Moveify clinic-website environment variables
# Copy to .env for local dev. In production, set these in Vercel →
# Project → Settings → Environment Variables.

# --- Google Reviews (api/reviews.js) ---
# Required. Places API (New) key. Restrict the key in Google Cloud Console to:
#   API: Places API (New)
#   Referrer: www.moveifyhealth.com, moveifyhealth.com, *.vercel.app
GOOGLE_PLACES_API_KEY=

# Optional. The Place ID for the business. If unset, the function looks it up
# via Text Search (slightly higher cost, still well within free tier).
# Find it at https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Optional. Override the business identity used for the Text Search fallback.
GOOGLE_BUSINESS_NAME=Moveify Health Solutions
GOOGLE_BUSINESS_ADDRESS=4 George St, Williamstown SA 5351, Australia

# --- Contact / Refer forms (api/contact.js, api/refer.js) ---
# These are already configured in production. Listed here for local dev only.
# EMAIL_FROM=
# CONTACT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY=
# TURNSTILE_SECRET_KEY=
