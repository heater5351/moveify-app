{
  "builds": [
    { "src": "tailwind css template/**", "use": "@vercel/static" },
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "api/refer.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact.js" },
    { "src": "/api/refer", "dest": "/api/refer.js" },
    { "src": "/refer", "dest": "/tailwind css template/refer.html" },
    { "src": "/((?!_vercel/).*)", "dest": "/tailwind css template/$1" }
  ]
}
